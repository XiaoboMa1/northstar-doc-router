// ===== human_review.json =====
// Filter: review_reason is not null. review_reason ∈
//   { conflict | low_confidence | llm_schema_mismatch
//   | llm_envelope_error | llm_api_error | llm_response_missing }.
// A consumer wanting the pure-conflict subset filters by
// classification.conflict == true within this file.
[
  // Example: conflict — string_match says "urgent" but LLM says "complaint"
  // with strong signals on both sides. Reconcile picks llm.keyword, sets
  // conflict=true, review_reason="conflict". route=="complaint" so this doc
  // does NOT appear in urgent.json.
  {
    "doc_id": "0737159fbb16b4d3",
    "source_path": "sample_docs/doc_005_urgent_or_contract.txt",
    "route": "complaint",
    "classification": {
      "string_match": {"keyword": "urgent", "hits": 2, "score": 1.0},
      "llm": {"keyword": "complaint", "score": 0.6},
      "conflict": true,
      "final_confidence": 0.48,
      "review_reason": "conflict"
    },
    "extracted_fields": {
      "customer_id": null,
      "issue_category": "access_denied",
      "severity": "high",
      "timeline": "immediate",
      "requested_resolution": "restore admin panel access"
    },
    "original_text": "Urgent Access Problem\n\nThe operations team cannot access the admin panel and needs urgent help immediately.\n",
    "batch_id": "batch_001",
    "error_reason": null
  },
  // Example: llm_schema_mismatch — LLM returned a record but extracted_fields
  // failed pydantic validation. route stays as reconciled keyword; fields
  // null; review_reason set. error_reason = llm_schema_mismatch
  {
    "doc_id": "7a13c0ff55221aa0",
    "source_path": "sample_docs/doc_007_contract_with_stray_refund.txt",
    "route": "contract",
    "classification": {
      "string_match": {"keyword": "contract", "hits": 3, "score": 1.0},
      "llm": {"keyword": "contract", "score": 0.82},
      "conflict": false,
      "final_confidence": 0.82,
      "review_reason": "llm_schema_mismatch"
    },
    "extracted_fields": null,
    "original_text": "Contract renewal note ... (truncated)\n",
    "batch_id": "batch_002",
    "error_reason": "llm_schema_mismatch"
  }
]

